# ─── NVIDIA API ───────────────────────────────────────────────
NVIDIA_API_KEY=nvapi-

# ─── NVIDIA NIM LLM (Cloud-hosted) ───────────────────────────
NIM_LLM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_LLM_MODEL=mistralai/ministral-14b-instruct-2512

# ─── Self-hosted NIM LLM (uncomment when ready) ──────────────
# NIM_LLM_BASE_URL=http://localhost:8000/v1
# NIM_LLM_MODEL=meta/llama-3.1-70b-instruct

# ─── NVIDIA Riva ASR (Cloud-hosted) ──────────────────────────
RIVA_ASR_URL=grpc.nvcf.nvidia.com:443

# ─── Self-hosted Riva ASR (uncomment when ready) ─────────────
# RIVA_ASR_URL=localhost:50051

# ─── NVIDIA Riva TTS (Cloud-hosted) ──────────────────────────
RIVA_TTS_URL=grpc.nvcf.nvidia.com:443

# ─── Self-hosted Riva TTS (uncomment when ready) ─────────────
# RIVA_TTS_URL=localhost:50051

# ─── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mydb

# ─── Server ───────────────────────────────────────────────────
BOT_HOST=0.0.0.0
BOT_PORT=7860
